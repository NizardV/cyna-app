<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for local dev (emulator 10.0.2.2, LAN). -->
    <!-- domain-config is intentionally avoided: Ktor CIO does not support  -->
    <!-- the hostname-aware checkServerTrusted required by Android when      -->
    <!-- domain-specific rules are present.                                  -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
